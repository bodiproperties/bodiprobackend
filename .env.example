# Neon pooled connection string (sslmode=require, host has "-pooler")
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Auth
JWT_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@bodi-properties.mn
ADMIN_PASSWORD=1234

# Server
PORT=4000
# Comma-separated allowed origins for CORS
CORS_ORIGIN=http://localhost:3000,https://bodi-properties.vercel.app,http://localhost:3001
